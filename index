<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>SIMETRÍA CONCE · Muebles en melamina a medida</title>
<meta name="description" content="Diseñamos, cortamos y armamos muebles en melamina a medida. Cocinas, closets y muebles de living con precisión de taller en la periferia de Concepción, Chile.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #181209;
    --bg-alt: #1f1810;
    --surface: #261d12;
    --surface-2: #2c2215;
    --oak: #c9893f;
    --oak-light: #e3ad6c;
    --bone: #f3ecdd;
    --bone-dim: #cbc0a9;
    --ink: #15110a;
    --blueprint: #7fa3ad;
    --line: rgba(243,236,221,0.12);
    --line-strong: rgba(243,236,221,0.22);
    --font-display: 'Space Grotesk', sans-serif;
    --font-body: 'Inter', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    --maxw: 1180px;
  }

  *{box-sizing:border-box; margin:0; padding:0;}
  html{scroll-behavior:smooth;}
  body{
    background:var(--bg);
    color:var(--bone);
    font-family:var(--font-body);
    line-height:1.5;
    -webkit-font-smoothing:antialiased;
    overflow-x:hidden;
  }
  img{max-width:100%; display:block;}
  a{color:inherit; text-decoration:none;}
  ul{list-style:none;}
  button{font-family:inherit; cursor:pointer;}

  ::selection{background:var(--oak); color:var(--ink);}

  :focus-visible{
    outline:2px solid var(--oak-light);
    outline-offset:3px;
  }

  .wrap{
    max-width:var(--maxw);
    margin:0 auto;
    padding:0 28px;
  }

  .eyebrow{
    font-family:var(--font-mono);
    font-size:12.5px;
    letter-spacing:0.14em;
    text-transform:uppercase;
    color:var(--oak-light);
    display:flex;
    align-items:center;
    gap:10px;
  }
  .eyebrow::before{
    content:"";
    width:18px; height:1px;
    background:var(--oak-light);
    display:inline-block;
  }

  h1,h2,h3{
    font-family:var(--font-display);
    font-weight:600;
    letter-spacing:-0.01em;
    color:var(--bone);
  }

  /* ===== NAV ===== */
  header{
    position:fixed; top:0; left:0; right:0;
    z-index:200;
    background:linear-gradient(to bottom, rgba(24,18,9,0.92), rgba(24,18,9,0));
    backdrop-filter:blur(2px);
  }
  .navbar{
    max-width:var(--maxw);
    margin:0 auto;
    padding:22px 28px;
    display:flex;
    align-items:center;
    justify-content:space-between;
  }
  .logo{
    display:flex; align-items:center; gap:10px;
    font-family:var(--font-display);
    font-weight:700;
    font-size:19px;
    letter-spacing:0.02em;
    color:var(--bone);
  }
  .logo svg{width:26px; height:26px;}

  .hamburger{
    width:48px; height:48px;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
    gap:6px;
    background:transparent;
    border:1px solid var(--line-strong);
    border-radius:999px;
    transition:border-color .25s ease, background .25s ease;
  }
  .hamburger:hover{ border-color:var(--oak); }
  .hamburger span{
    width:18px; height:1.5px;
    background:var(--bone);
    transition:transform .35s cubic-bezier(.65,0,.35,1), opacity .25s ease, width .25s ease;
  }
  .hamburger.open span:nth-child(1){ transform:translateY(7.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2){ opacity:0; }
  .hamburger.open span:nth-child(3){ transform:translateY(-7.5px) rotate(-45deg); }

  /* ===== OVERLAY MENU ===== */
  .menu-overlay{
    position:fixed; inset:0;
    z-index:190;
    background:var(--ink);
    background-image:
      linear-gradient(var(--line) 1px, transparent 1px),
      linear-gradient(90deg, var(--line) 1px, transparent 1px);
    background-size:48px 48px;
    display:flex;
    flex-direction:column;
    justify-content:center;
    padding:120px 28px 60px;
    opacity:0;
    visibility:hidden;
    transform:translateY(-12px);
    transition:opacity .45s ease, transform .45s ease, visibility 0s linear .45s;
  }
  .menu-overlay.open{
    opacity:1; visibility:visible; transform:translateY(0);
    transition:opacity .45s ease, transform .45s ease;
  }
  .menu-inner{ max-width:var(--maxw); margin:0 auto; width:100%; display:flex; gap:64px; flex-wrap:wrap; justify-content:space-between;}
  .menu-links{ display:flex; flex-direction:column; }
  .menu-links a{
    font-family:var(--font-display);
    font-size:clamp(34px, 7vw, 64px);
    font-weight:600;
    color:var(--bone-dim);
    padding:10px 0;
    border-bottom:1px solid var(--line);
    display:flex;
    align-items:baseline;
    gap:18px;
    transition:color .25s ease, padding-left .25s ease;
  }
  .menu-links a .num{
    font-family:var(--font-mono);
    font-size:14px;
    color:var(--oak);
  }
  .menu-links a:hover{ color:var(--bone); padding-left:14px;}
  .menu-side{
    display:flex; flex-direction:column; justify-content:flex-end; gap:18px;
    min-width:220px;
  }
  .menu-side p{ color:var(--bone-dim); font-size:14.5px;}
  .menu-side .mono{ font-family:var(--font-mono); color:var(--oak-light); font-size:13px; letter-spacing:.04em;}

  /* ===== HERO ===== */
  .hero{
    position:relative;
    min-height:100vh;
    display:flex;
    align-items:center;
    padding:140px 0 80px;
    background:
      radial-gradient(ellipse 900px 500px at 85% 18%, rgba(201,137,63,0.12), transparent 60%),
      var(--bg);
  }
  .hero .wrap{
    display:grid;
    grid-template-columns:1.05fr 0.95fr;
    gap:40px;
    align-items:center;
  }
  .hero h1{
    font-size:clamp(38px, 5.4vw, 70px);
    line-height:1.04;
    margin:18px 0 24px;
  }
  .hero h1 em{
    font-style:normal;
    color:var(--oak-light);
  }
  .hero p.lead{
    font-size:17px;
    color:var(--bone-dim);
    max-width:46ch;
    margin-bottom:34px;
  }
  .cta-row{ display:flex; gap:14px; flex-wrap:wrap; margin-bottom:46px;}
  .btn{
    display:inline-flex; align-items:center; gap:10px;
    padding:15px 26px;
    border-radius:999px;
    font-weight:600;
    font-size:14.5px;
    letter-spacing:0.01em;
    transition:transform .25s ease, background .25s ease, border-color .25s ease;
  }
  .btn-primary{
    background:var(--oak);
    color:var(--ink);
  }
  .btn-primary:hover{ background:var(--oak-light); transform:translateY(-2px);}
  .btn-ghost{
    border:1px solid var(--line-strong);
    color:var(--bone);
  }
  .btn-ghost:hover{ border-color:var(--oak); transform:translateY(-2px); }

  .hero-stats{
    display:flex; gap:34px;
    padding-top:28px;
    border-top:1px solid var(--line);
  }
  .hero-stats div strong{
    display:block;
    font-family:var(--font-display);
    font-size:26px;
    color:var(--bone);
  }
  .hero-stats div span{
    font-family:var(--font-mono);
    font-size:11.5px;
    color:var(--bone-dim);
    letter-spacing:.05em;
    text-transform:uppercase;
  }

  /* ===== HERO SIGNATURE DIAGRAM ===== */
  .diagram-wrap{ position:relative; }
  .diagram-wrap svg{ width:100%; height:auto; overflow:visible; }
  .piece{
    transform:translate(var(--ox), var(--oy)) rotate(var(--rot,0deg));
    opacity:0;
    animation:assemble 1.1s cubic-bezier(.16,1,.3,1) forwards;
    animation-delay:var(--delay);
    transform-box:fill-box;
    transform-origin:center;
  }
  @keyframes assemble{
    0%{ transform:translate(var(--ox), var(--oy)) rotate(var(--rot,0deg)); opacity:0; }
    55%{ opacity:1; }
    100%{ transform:translate(0,0) rotate(0deg); opacity:1; }
  }
  .dim-line{
    stroke:var(--blueprint);
    stroke-width:1;
    opacity:0;
    stroke-dasharray:4 3;
    animation:fadein .6s ease forwards;
    animation-delay:1.5s;
  }
  .dim-label{
    font-family:var(--font-mono);
    font-size:11px;
    fill:var(--blueprint);
    opacity:0;
    animation:fadein .6s ease forwards;
    animation-delay:1.6s;
  }
  @keyframes fadein{ to{ opacity:1; } }

  /* ===== SECTION SHELL ===== */
  section{ padding:120px 0; position:relative; }
  .section-head{
    display:flex; justify-content:space-between; align-items:flex-end;
    gap:24px; margin-bottom:64px; flex-wrap:wrap;
  }
  .section-head h2{ font-size:clamp(28px, 4vw, 44px); margin-top:14px; max-width:18ch;}
  .section-head .sub{ color:var(--bone-dim); max-width:36ch; font-size:15.5px;}

  .reveal{ opacity:0; transform:translateY(28px); transition:opacity .7s ease, transform .7s ease; }
  .reveal.in{ opacity:1; transform:translateY(0); }

  /* ===== SERVICIOS ===== */
  .services{ background:var(--bg-alt); border-top:1px solid var(--line); border-bottom:1px solid var(--line);}
  .service-grid{
    display:grid;
    grid-template-columns:repeat(4,1fr);
    gap:1px;
    background:var(--line);
    border:1px solid var(--line);
  }
  .service-card{
    background:var(--bg-alt);
    padding:34px 26px 30px;
    transition:background .3s ease;
  }
  .service-card:hover{ background:var(--surface); }
  .service-card .ico{
    width:38px; height:38px;
    margin-bottom:22px;
    color:var(--oak);
  }
  .service-card h3{ font-size:18px; margin-bottom:10px; }
  .service-card p{ font-size:14px; color:var(--bone-dim); }

  /* ===== PROCESO ===== */
  .process-list{ border-top:1px solid var(--line); }
  .process-item{
    display:grid;
    grid-template-columns:90px 1fr 1.4fr;
    gap:24px;
    align-items:center;
    padding:32px 0;
    border-bottom:1px solid var(--line);
  }
  .process-item .pnum{
    font-family:var(--font-mono);
    font-size:13px;
    color:var(--oak);
  }
  .process-item h3{ font-size:21px; }
  .process-item p{ color:var(--bone-dim); font-size:14.5px; }
  .process-item .bracket{
    position:relative; width:100%; height:2px; background:var(--line);
  }

  /* ===== PROYECTOS ===== */
  .gallery{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:22px;
  }
  .project-card{
    position:relative;
    border-radius:6px;
    overflow:hidden;
    aspect-ratio:4/5;
    border:1px solid var(--line);
  }
  .project-card .swatch{
    position:absolute; inset:0;
  }
  .project-card .grain{
    position:absolute; inset:0;
    background-image:repeating-linear-gradient(100deg, rgba(0,0,0,0.12) 0px, rgba(0,0,0,0.12) 2px, transparent 2px, transparent 7px);
    mix-blend-mode:overlay;
  }
  .project-card .tag{
    position:absolute; left:16px; top:16px;
    font-family:var(--font-mono); font-size:11px;
    background:rgba(21,17,10,0.55);
    border:1px solid rgba(243,236,221,0.25);
    color:var(--bone);
    padding:5px 10px;
    border-radius:999px;
    backdrop-filter:blur(4px);
  }
  .project-card .meta{
    position:absolute; left:0; right:0; bottom:0;
    padding:22px 18px;
    background:linear-gradient(to top, rgba(21,17,10,0.92), transparent);
  }
  .project-card .meta h3{ font-size:18px; margin-bottom:4px;}
  .project-card .meta span{
    font-family:var(--font-mono); font-size:11.5px; color:var(--oak-light);
  }
  .sw1{ background:linear-gradient(135deg,#caa06a,#8a6238); }
  .sw2{ background:linear-gradient(135deg,#e9e2d4,#bdb29a); }
  .sw3{ background:linear-gradient(135deg,#5b4631,#2c2014); }
  .sw4{ background:linear-gradient(135deg,#9a9189,#5c564f); }
  .sw5{ background:linear-gradient(135deg,#7c5230,#3a2415); }
  .sw6{ background:linear-gradient(135deg,#d8c7a1,#a78e60); }

  /* ===== MATERIALES ===== */
  .materials{ background:var(--bg-alt); border-top:1px solid var(--line); border-bottom:1px solid var(--line);}
  .mat-grid{
    display:grid;
    grid-template-columns:repeat(6,1fr);
    gap:16px;
  }
  .mat-chip{ text-align:center; }
  .mat-chip .swatch{
    width:100%; aspect-ratio:1/1;
    border-radius:8px;
    margin-bottom:12px;
    border:1px solid var(--line-strong);
  }
  .mat-chip .name{ font-size:13px; color:var(--bone); font-weight:500;}
  .mat-chip .code{ font-family:var(--font-mono); font-size:10.5px; color:var(--bone-dim);}

  /* ===== TESTIMONIOS ===== */
  .testi-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--line); border:1px solid var(--line);}
  .testi-card{ background:var(--bg); padding:32px 28px; }
  .testi-card p{ color:var(--bone-dim); font-size:15px; margin-bottom:22px; line-height:1.65;}
  .testi-card .who{ font-family:var(--font-mono); font-size:12px; color:var(--oak-light); }
  .stars{ color:var(--oak); font-size:14px; margin-bottom:14px; letter-spacing:2px;}

  /* ===== CONTACTO ===== */
  .contact{ background:var(--bg-alt); border-top:1px solid var(--line);}
  .contact-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:60px;
  }
  .field{ margin-bottom:20px; }
  .field label{
    display:block; font-family:var(--font-mono); font-size:11.5px;
    text-transform:uppercase; letter-spacing:.06em; color:var(--bone-dim);
    margin-bottom:8px;
  }
  .field input, .field select, .field textarea{
    width:100%;
    background:var(--surface);
    border:1px solid var(--line-strong);
    border-radius:6px;
    padding:13px 14px;
    color:var(--bone);
    font-family:var(--font-body);
    font-size:14.5px;
    transition:border-color .2s ease;
  }
  .field input:focus, .field select:focus, .field textarea:focus{ border-color:var(--oak); outline:none; }
  .field textarea{ resize:vertical; min-height:100px; }

  .contact-info{ display:flex; flex-direction:column; justify-content:space-between; }
  .info-block{ margin-bottom:28px; }
  .info-block .eyebrow{ margin-bottom:10px; }
  .info-block a, .info-block p{ font-size:15px; color:var(--bone); }
  .info-block .small{ color:var(--bone-dim); font-size:13.5px; margin-top:4px;}

  .info-card{
    background:var(--surface);
    border:1px solid var(--line-strong);
    border-radius:10px;
    padding:26px;
  }
  .info-card .dim{
    display:flex; justify-content:space-between;
    font-family:var(--font-mono); font-size:12px; color:var(--bone-dim);
    padding:8px 0; border-bottom:1px dashed var(--line);
  }
  .info-card .dim:last-child{ border-bottom:none; }
  .info-card .dim b{ color:var(--oak-light); font-weight:500; }

  /* ===== FOOTER ===== */
  footer{ padding:60px 0 40px; border-top:1px solid var(--line); }
  .footer-top{
    display:flex; justify-content:space-between; align-items:center;
    flex-wrap:wrap; gap:24px; margin-bottom:40px;
  }
  .footer-nav{ display:flex; gap:28px; flex-wrap:wrap; }
  .footer-nav a{ font-size:13.5px; color:var(--bone-dim); }
  .footer-nav a:hover{ color:var(--oak-light); }
  .footer-bottom{
    display:flex; justify-content:space-between; flex-wrap:wrap; gap:10px;
    font-family:var(--font-mono); font-size:11.5px; color:var(--bone-dim);
    padding-top:24px; border-top:1px solid var(--line);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width:980px){
    .hero .wrap{ grid-template-columns:1fr; }
    .diagram-wrap{ order:-1; max-width:380px; margin:0 auto 20px; }
    .service-grid{ grid-template-columns:repeat(2,1fr); }
    .gallery{ grid-template-columns:repeat(2,1fr); }
    .mat-grid{ grid-template-columns:repeat(3,1fr); }
    .testi-grid{ grid-template-columns:1fr; }
    .contact-grid{ grid-template-columns:1fr; gap:40px;}
    .process-item{ grid-template-columns:50px 1fr; }
    .process-item .bracket{ display:none; }
    .menu-links a{ font-size:clamp(28px,9vw,46px); }
    .menu-inner{ gap:32px; }
  }
  @media (max-width:560px){
    .service-grid{ grid-template-columns:1fr; }
    .gallery{ grid-template-columns:1fr; }
    .mat-grid{ grid-template-columns:repeat(2,1fr); }
    .hero{ padding-top:120px; }
    section{ padding:80px 0; }
    .hero-stats{ gap:22px; flex-wrap:wrap; }
  }

  @media (prefers-reduced-motion: reduce){
    *{ animation-duration:0.001s !important; transition-duration:0.001s !important; scroll-behavior:auto !important; }
  }
</style>
</head>
<body>

<header>
  <div class="navbar">
    <a href="#inicio" class="logo">
      <svg viewBox="0 0 26 26" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M3 23V3H9V9H23V15H15V23H3Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/>
      </svg>
      SIMETRÍA CONCE
    </a>
    <button class="hamburger" id="hamburgerBtn" aria-label="Abrir menú" aria-expanded="false">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<nav class="menu-overlay" id="menuOverlay">
  <div class="wrap menu-inner">
    <div class="menu-links">
      <a href="#inicio" data-link><span class="num">00</span> Inicio</a>
      <a href="#servicios" data-link><span class="num">01</span> Servicios</a>
      <a href="#proceso" data-link><span class="num">02</span> Proceso</a>
      <a href="#proyectos" data-link><span class="num">03</span> Proyectos</a>
      <a href="#materiales" data-link><span class="num">04</span> Materiales</a>
      <a href="#contacto" data-link><span class="num">05</span> Contacto</a>
    </div>
    <div class="menu-side">
      <p>Taller de melamina a medida.<br>Chillán Viejo, Región de Ñuble.</p>
      <span class="mono">+56 9 0000 0000</span>
      <span class="mono">hola@simetriaconce.cl</span>
      <span class="mono">@simetriaconce</span>
    </div>
  </div>
</nav>

<main>

  <!-- HERO -->
  <section class="hero" id="inicio">
    <div class="wrap">
      <div class="hero-copy">
        <span class="eyebrow">Taller de melamina a medida</span>
        <h1>Muebles cortados<br>al <em>milímetro.</em></h1>
        <p class="lead">Diseñamos, cortamos y armamos cocinas, closets y muebles a medida. Cada pieza sale del taller con la precisión de un plano y la terminación de una mueblería fina.</p>
        <div class="cta-row">
          <a href="#contacto" class="btn btn-primary">Pedir cotización</a>
          <a href="#proyectos" class="btn btn-ghost">Ver proyectos</a>
        </div>
        <div class="hero-stats">
          <div><strong>120+</strong><span>Proyectos entregados</span></div>
          <div><strong>±1mm</strong><span>Tolerancia de corte</span></div>
          <div><strong>6</strong><span>Años de taller</span></div>
        </div>
      </div>

      <div class="diagram-wrap">
        <svg viewBox="0 0 520 460" xmlns="http://www.w3.org/2000/svg">
          <!-- back panel -->
          <rect class="piece" style="--ox:-60px; --oy:-20px; --rot:-6deg; --delay:0s;" x="160" y="90" width="240" height="290" rx="3" fill="#3a2c1c"/>
          <!-- left side -->
          <rect class="piece" style="--ox:-90px; --oy:10px; --rot:-10deg; --delay:.12s;" x="140" y="70" width="22" height="330" rx="2" fill="#c9893f"/>
          <!-- right side -->
          <rect class="piece" style="--ox:90px; --oy:-10px; --rot:10deg; --delay:.2s;" x="398" y="70" width="22" height="330" rx="2" fill="#c9893f"/>
          <!-- top -->
          <rect class="piece" style="--ox:0px; --oy:-90px; --rot:4deg; --delay:.32s;" x="140" y="68" width="280" height="22" rx="2" fill="#e3ad6c"/>
          <!-- bottom -->
          <rect class="piece" style="--ox:0px; --oy:90px; --rot:-4deg; --delay:.32s;" x="140" y="378" width="280" height="22" rx="2" fill="#e3ad6c"/>
          <!-- shelf -->
          <rect class="piece" style="--ox:-70px; --oy:0px; --rot:3deg; --delay:.46s;" x="170" y="225" width="220" height="10" rx="2" fill="#8a6238"/>
          <!-- door left -->
          <rect class="piece" style="--ox:-50px; --oy:60px; --rot:-3deg; --delay:.6s;" x="170" y="110" width="118" height="260" rx="2" fill="#caa06a" opacity="0.96"/>
          <!-- door right -->
          <rect class="piece" style="--ox:50px; --oy:60px; --rot:3deg; --delay:.68s;" x="292" y="110" width="118" height="260" rx="2" fill="#caa06a" opacity="0.96"/>
